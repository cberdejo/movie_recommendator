# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=movies_collection

# --- MCP ---
MCP_HOST=0.0.0.0
MCP_PORT=5000

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mysecretpassword
POSTGRES_DB=chatdb

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Frontend 
VITE_API_BASE=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/api/v1/ws/movies

# --- LLM / LiteLLM ---
LITELLM_URL=http://litellm:4000

# --- Redis ---
REDIS_URL=redis://redis:6379/0
STREAM_KEY_PREFIX=stream:chat:
STREAM_TTL=3600
ACTIVE_GENERATION_TTL=3600
INTERRUPT_TTL=3600

# --- Logging ---
ENVIRONMENT=development
LOG_LEVEL=info
LOG_FORMAT=text

# --- Langfuse (optional) ---
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_SAMPLE_RATE=1.0

